  create  table "weather"."gold"."fact_weather_events__dbt_tmp"
  
  
    as
  
  (
    

select
    e.event_id,

    l.location_id,
d.date_sk,
    e.airport_code,
    w.weather_event_id,
    e.start_time,
    e.end_time,
    e.duration_minutes,
    e.precipitation_in
   

from "weather"."gold"."stg_weather_events" e

left join "weather"."gold"."dim_location" l
    on e.airport_code = l.airport_code
   and e.city = l.city
   and e.county = l.county
   and e.state = l.state
   and e.zipcode = l.zipcode
left join "weather"."gold"."dim_date" d
    on make_date(e.year, e.month, e.day) = d.date

left join "weather"."gold"."dim_weather_event" w
    on e.event_type = w.event_type
   and e.severity = w.severity
  );
  
